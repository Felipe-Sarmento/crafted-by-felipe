---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group by "YYYY - Month"
const grouped = new Map<string, typeof posts>();
for (const post of posts) {
  const d = post.data.pubDate;
  const key = `${d.getFullYear()} - ${d.toLocaleString('en-US', { month: 'long' })}`;
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(post);
}
---

<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <Header />

    <main class="mx-auto max-w-3xl px-4 py-12">
      <h1 class="mb-10 text-3xl font-bold text-gray-900 dark:text-gray-50">
        {SITE_TITLE} Blog
      </h1>

      {Array.from(grouped.entries()).map(([group, groupPosts]) => (
        <section class="mb-10">
          <h2 class="mb-4 border-b border-gray-200 pb-2 text-xl font-semibold text-gray-700 dark:border-gray-800 dark:text-gray-300">
            {group}
          </h2>
          <ul class="space-y-3">
            {groupPosts.map((post) => (
              <li>
                <a
                  href={getPostUrl(post)}
                  class="group flex items-baseline gap-3 no-underline"
                >
                  <span class="text-base text-gray-900 group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
                    {post.data.title}
                  </span>
                  <span class="hidden shrink-0 text-xs text-gray-400 sm:inline dark:text-gray-500">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>

    <Footer />
  </body>
</html>
